{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PrviLabos HTTPS",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build PrviLabos",
            "program": "${workspaceFolder}/PrviLabos/bin/Debug/net9.0/PrviLabos.dll",
            "args": [],
            "cwd": "${workspaceFolder}/PrviLabos",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https://\\S+)",
                "uriFormat": "%s/racun/prijava"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7002;http://localhost:5276"
            }
        }
    ]
}
