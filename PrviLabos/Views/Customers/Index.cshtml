@model IEnumerable<PrviLabos.Model.Customer>
@{
    ViewData["Title"] = "Customers";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">Customers</span>
    </nav>
}

<section class="ux-surface-card">
    <header class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Customer Directory</h2>
            <p class="ux-muted">Overview of renters and linked activity.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <label class="visually-hidden" for="customer-search">Search customers</label>
            <input id="customer-search"
                   class="form-control ux-customer-search"
                   type="search"
                   placeholder="Search name, email or phone"
                   autocomplete="off"
                   data-ux-customer-search />
            <a class="ux-button-primary" asp-action="Create">New Customer</a>
        </div>
    </header>
    <div class="ux-table-wrap">
        <table class="ux-table" data-ux-customer-table>
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Bookings</th>
                    <th>Tickets</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody data-ux-customer-table-body>
                @await Html.PartialAsync("_CustomerRows", Model)
            </tbody>
        </table>
    </div>
</section>

