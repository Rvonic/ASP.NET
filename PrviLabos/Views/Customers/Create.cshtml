@model PrviLabos.Models.CustomerCreateModel
@using PrviLabos.Models

@{
    ViewData["Title"] = "Novi kupac";
}

<div class="ux-surface-card">
    <div class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Novi kupac</h2>
            <p class="ux-muted">Unesi osnovne podatke kupca i datum rođenja.</p>
        </div>
        <a class="ux-text-link" asp-action="Index">Natrag na popis</a>
    </div>

    <form asp-action="Create" method="post" class="row g-3 align-items-start">
        @Html.AntiForgeryToken()

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="FirstName" class="form-label"></label>
                <span asp-validation-for="FirstName" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="FirstName" class="form-control" />
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="LastName" class="form-label"></label>
                <span asp-validation-for="LastName" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="LastName" class="form-control" />
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="Email" class="form-label"></label>
                <span asp-validation-for="Email" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="Email" class="form-control" type="email" placeholder="ime@domena.com" />
        </div>

        <div class="col-12 col-xl-8" data-ux-phone-control>
            <label class="form-label">Broj telefona</label>
            <div class="ux-phone-row">
                <div>
                    @await Html.PartialAsync("_PhoneCountryControl", new PhoneCountryControlViewModel
                    {
                        Name = nameof(Model.PhoneCountryCode),
                        Id = "customer-phone-country-code",
                        Label = "Država",
                        Value = Model.PhoneCountryCode
                    })
                    <span asp-validation-for="PhoneCountryCode" class="ux-field-validation text-danger"></span>
                </div>

                <div>
                    <div class="ux-field-label-row">
                        <label asp-for="PhoneLocalNumber" class="form-label">Lokalni broj</label>
                        <span asp-validation-for="PhoneLocalNumber" class="ux-field-validation text-danger"></span>
                    </div>
                    <input asp-for="PhoneLocalNumber" class="form-control ux-phone-local-input" type="tel" inputmode="numeric" placeholder="977888842" maxlength="9" data-ux-phone-local-input />
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="DriverLicenseNumber" class="form-label"></label>
                <span asp-validation-for="DriverLicenseNumber" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="DriverLicenseNumber" class="form-control" placeholder="AA1234567" maxlength="9" />
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_DateTimeControl", new DateTimeControlViewModel
            {
                Name = nameof(Model.DateOfBirth),
                Id = "customer-date-of-birth",
                Label = "Datum rođenja",
                Value = null,
                IsRequired = true,
                ShowTime = false
            })
        </div>

        <div class="col-12 d-flex flex-wrap gap-2 pt-2">
            <button type="submit" class="ux-button-primary">Spremi</button>
            <a asp-action="Index" class="ux-button-secondary">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}