@model IEnumerable<PrviLabos.Model.Vehicle>
@{
    ViewData["Title"] = "Vehicles";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">Vehicles</span>
    </nav>
}

<section class="ux-surface-card">
    <header class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Fleet Directory</h2>
            <p class="ux-muted">Vehicle availability, location, and utilization at a glance.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <label class="visually-hidden" for="vehicle-search">Search vehicles</label>
            <input id="vehicle-search"
                   class="form-control ux-vehicle-search"
                   type="search"
                   placeholder="Search plate, brand, model or location"
                   autocomplete="off"
                   data-ux-vehicle-search />
            <a class="ux-button-primary" asp-action="Create">New Vehicle</a>
        </div>
    </header>
    <div class="ux-table-wrap">
        <table class="ux-table" data-ux-vehicle-table>
            <thead>
                <tr>
                    <th>Vehicle</th>
                    <th>Plate</th>
                    <th>Category</th>
                    <th>Location</th>
                    <th>Availability</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody data-ux-vehicle-table-body>
                @await Html.PartialAsync("_VehicleRows", Model)
            </tbody>
        </table>
    </div>
</section>
