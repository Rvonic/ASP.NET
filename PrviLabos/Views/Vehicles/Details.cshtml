@model PrviLabos.Model.Vehicle
@{
    ViewData["Title"] = "Vehicle Details";
    var relatedBookings = Model.Bookings.OrderByDescending(b => b.PickupAt).ToList();
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <a asp-controller="Vehicles" asp-action="Index">Vehicles</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">@Model.PlateNumber</span>
    </nav>
}

<section class="ux-detail-grid">
    <article class="ux-surface-card">
        <header class="ux-panel-header">
            <div>
                <p class="ux-eyebrow">Manufacturer profile</p>
                <h2 class="ux-section-title">@Model.Brand @Model.Model</h2>
            </div>
            <div class="d-flex gap-2">
                <a class="ux-button-secondary" asp-action="Edit" asp-route-id="@Model.Id">Uredi</a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="ux-button-danger">Obriši</button>
                </form>
            </div>
        </header>
        @if (TempData["DeleteError"] is string deleteError)
        {
            <div class="ux-inline-alert ux-inline-alert-danger" role="alert">@deleteError</div>
        }
        <div class="ux-vehicle-hero">
            <div class="ux-vehicle-profile-card">
                <div class="ux-vehicle-profile-head">
                    @await Html.PartialAsync("_VehicleBrandBadge", Model)
                    <div class="ux-vehicle-profile-copy">
                        <span class="ux-vehicle-profile-plate">@Model.PlateNumber</span>
                        <span class="ux-pill">@(Model.IsAvailable ? "Available" : "Unavailable")</span>
                    </div>
                </div>

                <dl class="ux-detail-list">
                    <dt>Category</dt>
                    <dd>@Model.Category</dd>
                    <dt>Production year</dt>
                    <dd>@Model.ProductionYear</dd>
                    <dt>Current mileage</dt>
                    <dd>@Model.CurrentMileage km</dd>
                    <dt>Daily rate</dt>
                    <dd>@Model.DailyRate.ToString("0.00") EUR</dd>
                    <dt>Current location</dt>
                    <dd>
                        @if (Model.CurrentLocation is null)
                        {
                            <span>Not assigned</span>
                        }
                        else
                        {
                            <a class="ux-ticket-customer-link" asp-controller="Locations" asp-action="Details" asp-route-id="@Model.CurrentLocation.Id">@Model.CurrentLocation.Name, @Model.CurrentLocation.City</a>
                        }
                    </dd>
                </dl>
            </div>

            <div class="ux-vehicle-stat-grid">
                <article class="ux-vehicle-stat">
                    <p class="ux-vehicle-stat-label">Availability</p>
                    <p class="ux-vehicle-stat-value">@(Model.IsAvailable ? "Available" : "Unavailable")</p>
                </article>
                <article class="ux-vehicle-stat">
                    <p class="ux-vehicle-stat-label">Category</p>
                    <p class="ux-vehicle-stat-value">@Model.Category</p>
                </article>
                <article class="ux-vehicle-stat">
                    <p class="ux-vehicle-stat-label">Year</p>
                    <p class="ux-vehicle-stat-value">@Model.ProductionYear</p>
                </article>
                <article class="ux-vehicle-stat">
                    <p class="ux-vehicle-stat-label">Mileage</p>
                    <p class="ux-vehicle-stat-value">@Model.CurrentMileage km</p>
                </article>
            </div>
        </div>
    </article>

    <article class="ux-surface-card">
        <header class="ux-panel-header">
            <div>
                <h2 class="ux-section-title">Recent bookings</h2>
                <p class="ux-muted">Latest reservations for this vehicle.</p>
            </div>
        </header>
        @if (relatedBookings.Count == 0)
        {
            <p class="ux-muted">No bookings linked to this vehicle.</p>
        }
        else
        {
            <div class="ux-table-wrap">
                <table class="ux-table">
                    <thead>
                        <tr>
                            <th>Reservation</th>
                            <th>Customer</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var booking in relatedBookings.Take(5))
                    {
                        <tr>
                            <td><a class="ux-text-link" asp-controller="Bookings" asp-action="Details" asp-route-id="@booking.Id">@booking.ReservationCode</a></td>
                            <td><a class="ux-text-link" asp-controller="Customers" asp-action="Details" asp-route-id="@booking.Customer.Id">@booking.Customer.FirstName @booking.Customer.LastName</a></td>
                            <td>@booking.Status</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>
