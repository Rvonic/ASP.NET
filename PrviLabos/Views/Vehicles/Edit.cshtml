@model PrviLabos.Models.VehicleEditModel
@using PrviLabos.Model

@{
    ViewData["Title"] = "Uredi vozilo";
}

<div class="ux-surface-card">
    <div class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Uredi vozilo</h2>
            <p class="ux-muted">Ažuriraj osnovne podatke, lokaciju i status dostupnosti.</p>
        </div>
        <a class="ux-text-link" asp-action="Details" asp-route-id="@Model.Id">Natrag na detalje</a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="col-md-4">
            <label asp-for="PlateNumber" class="form-label"></label>
            <input asp-for="PlateNumber" class="form-control" />
            <span asp-validation-for="PlateNumber" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Brand" class="form-label"></label>
            <input asp-for="Brand" class="form-control" />
            <span asp-validation-for="Brand" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Model" class="form-label"></label>
            <input asp-for="Model" class="form-control" />
            <span asp-validation-for="Model" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="ProductionYear" class="form-label"></label>
            <input asp-for="ProductionYear" class="form-control" type="number" min="1900" max="2100" />
            <span asp-validation-for="ProductionYear" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="Category" class="form-label"></label>
            <select asp-for="Category" asp-items="ViewBag.VehicleCategories" class="form-select"></select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="DailyRate" class="form-label"></label>
            <input asp-for="DailyRate" class="form-control" type="number" min="0" step="0.01" />
            <span asp-validation-for="DailyRate" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label asp-for="CurrentMileage" class="form-label"></label>
            <input asp-for="CurrentMileage" class="form-control" type="number" min="0" />
            <span asp-validation-for="CurrentMileage" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="CurrentLocationId" class="form-label">Current location</label>
            <select asp-for="CurrentLocationId" asp-items="ViewBag.CurrentLocations" class="form-select">
                <option value="">Not assigned</option>
            </select>
            <span asp-validation-for="CurrentLocationId" class="text-danger"></span>
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="ux-button-primary">Spremi</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="ux-button-secondary">Odustani</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}