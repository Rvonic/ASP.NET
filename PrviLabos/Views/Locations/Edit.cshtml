@model PrviLabos.Models.LocationEditModel
@using PrviLabos.Models

@{
    ViewData["Title"] = "Edit Location";
}

<div class="ux-surface-card">
    <div class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Edit Location</h2>
            <p class="ux-muted">Update location details and operating hours.</p>
        </div>
        <a class="ux-text-link" asp-action="Details" asp-route-id="@Model.Id">Back to Details</a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3 align-items-start">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="Name" class="form-label"></label>
                <span asp-validation-for="Name" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="City" class="form-label"></label>
                <span asp-validation-for="City" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="City" class="form-control" />
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="Address" class="form-label"></label>
                <span asp-validation-for="Address" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="Address" class="form-control" />
        </div>

        <div class="col-12 col-xl-8" data-ux-phone-control>
            <label class="form-label">Phone Number</label>
            <div class="ux-phone-row">
                <div>
                    @await Html.PartialAsync("_PhoneCountryControl", new PhoneCountryControlViewModel
                    {
                        Name = nameof(Model.PhoneCountryCode),
                        Id = "location-phone-country-code",
                        Label = "Country",
                        Value = Model.PhoneCountryCode
                    })
                    <span asp-validation-for="PhoneCountryCode" class="ux-field-validation text-danger"></span>
                </div>

                <div>
                    <div class="ux-field-label-row">
                        <label asp-for="PhoneLocalNumber" class="form-label">Local Number</label>
                        <span asp-validation-for="PhoneLocalNumber" class="ux-field-validation text-danger"></span>
                    </div>
                    <input asp-for="PhoneLocalNumber" class="form-control ux-phone-local-input" type="tel" inputmode="numeric" placeholder="977888842" maxlength="15" data-ux-phone-local-input />
                </div>
            </div>
        </div>

        <div class="col-md-4 col-xl-3">
            @await Html.PartialAsync("_TimeControl", new TimeControlViewModel
            {
                Name = nameof(Model.OpenAt),
                Id = "location-open-at",
                Label = "Open At",
                Value = Model.OpenAt,
                IsRequired = true
            })
        </div>

        <div class="col-md-4 col-xl-3">
            @await Html.PartialAsync("_TimeControl", new TimeControlViewModel
            {
                Name = nameof(Model.CloseAt),
                Id = "location-close-at",
                Label = "Close At",
                Value = Model.CloseAt,
                IsRequired = true
            })
        </div>

        <div class="col-md-4 col-xl-3">
            <div class="ux-field-label-row">
                <label asp-for="ParkingCapacity" class="form-label">Parking Capacity</label>
                <span asp-validation-for="ParkingCapacity" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="ParkingCapacity" class="form-control" type="number" min="1" step="1" inputmode="numeric" />
        </div>

        <div class="col-12 d-flex flex-wrap gap-2 pt-2">
            <button type="submit" class="ux-button-primary">Save</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="ux-button-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
