@model IEnumerable<PrviLabos.Model.Location>
@{
    ViewData["Title"] = "Locations";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">Locations</span>
    </nav>
}

<section class="ux-surface-card">
    <header class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Location Directory</h2>
            <p class="ux-muted">Operational points and their current fleet capacity.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <label class="visually-hidden" for="location-search">Search locations</label>
            <input id="location-search"
                   class="form-control ux-location-search"
                   type="search"
                   placeholder="Search name, city, address or phone"
                   autocomplete="off"
                   data-ux-location-search />
            <a class="ux-button-primary" asp-action="Create">New Location</a>
        </div>
    </header>
    <div class="ux-table-wrap">
        <table class="ux-table" data-ux-location-table>
            <thead>
                <tr>
                    <th>Location</th>
                    <th>City</th>
                    <th>Contact</th>
                    <th>Capacity</th>
                    <th>Vehicles</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody data-ux-location-table-body>
                @await Html.PartialAsync("_LocationRows", Model)
            </tbody>
        </table>
    </div>
</section>
