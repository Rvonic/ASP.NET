@model PrviLabos.Domain.SupportTicket
@{
    ViewData["Title"] = "Ticket Details";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <a asp-controller="Tickets" asp-action="Index">Tickets</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">@Model.TicketNumber</span>
    </nav>
}

<section class="ux-detail-grid">
    <article class="ux-surface-card">
        <h2 class="ux-section-title">Ticket @Model.TicketNumber</h2>
        <dl class="ux-detail-list">
            <dt>Status</dt>
            <dd>@Model.Status</dd>
            <dt>Priority</dt>
            <dd>@Model.Priority</dd>
            <dt>Created</dt>
            <dd>@Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd>
            <dt>Requested dropoff</dt>
            <dd><a class="ux-ticket-customer-link" asp-controller="Locations" asp-action="Details" asp-route-id="@Model.RequestedDropoffLocation.Id">@Model.RequestedDropoffLocation.Name, @Model.RequestedDropoffLocation.City</a></dd>
            <dt>Booking</dt>
            <dd><a class="ux-text-link" asp-controller="Bookings" asp-action="Details" asp-route-id="@Model.Booking.Id">@Model.Booking.ReservationCode</a></dd>
            <dt>Customer</dt>
            <dd><a class="ux-text-link" asp-controller="Customers" asp-action="Details" asp-route-id="@Model.Booking.Customer.Id">@Model.Booking.Customer.FirstName @Model.Booking.Customer.LastName</a></dd>
        </dl>
    </article>

    <article class="ux-surface-card">
        <header class="ux-panel-header">
            <div>
                <h2 class="ux-section-title">Case details</h2>
                <p class="ux-muted">Description and assigned agent team.</p>
            </div>
        </header>
        <p class="ux-description">@Model.Description</p>

        <h3 class="ux-subsection-title">Assigned agents</h3>
        @if (Model.AssignedAgents.Count == 0)
        {
            <p class="ux-muted">No agents assigned yet.</p>
        }
        else
        {
            <ul class="ux-agent-list">
                @foreach (var agent in Model.AssignedAgents)
                {
                    <li>
                        <strong>
                            <a class="ux-ticket-customer-link" asp-controller="Agents" asp-action="Details" asp-route-id="@agent.Id">@agent.FullName</a>
                        </strong>
                        <span class="ux-muted">@agent.TeamName</span>
                    </li>
                }
            </ul>
        }
    </article>
</section>