@model IEnumerable<PrviLabos.Model.SupportTicket>
@{
    ViewData["Title"] = "Tickets";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">Tickets</span>
    </nav>
}

<section class="ux-surface-card">
    <header class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Support Queue</h2>
            <p class="ux-muted">Investigate and route customer dropoff issues.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <label class="visually-hidden" for="ticket-search">Search tickets</label>
            <input id="ticket-search"
                   class="form-control ux-ticket-search"
                   type="search"
                   placeholder="Search ticket, booking, customer or status"
                   autocomplete="off"
                   data-ux-ticket-search />
            <a class="ux-button-primary" asp-action="Create">Create Ticket</a>
        </div>
    </header>
    <div class="ux-table-wrap">
        <table class="ux-table" data-ux-ticket-table>
            <thead>
                <tr>
                    <th>Ticket</th>
                    <th>Booking</th>
                    <th>Customer</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody data-ux-ticket-table-body>
                @await Html.PartialAsync("_TicketRows", Model)
            </tbody>
        </table>
    </div>
</section>