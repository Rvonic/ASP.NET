@model IEnumerable<PrviLabos.Model.Booking>

@if (!Model.Any())
{
    <tr>
        <td colspan="6" class="text-center ux-muted">No bookings found.</td>
    </tr>
}
else
{
    foreach (var booking in Model)
    {
        <tr>
            <td><a class="ux-text-link" asp-action="Details" asp-route-id="@booking.Id">@booking.ReservationCode</a></td>
            <td><a class="ux-text-link" asp-controller="Customers" asp-action="Details" asp-route-id="@booking.Customer.Id">@booking.Customer.FirstName @booking.Customer.LastName</a></td>
            <td>
                <a class="ux-text-link ux-vehicle-inline" asp-controller="Vehicles" asp-action="Details" asp-route-id="@booking.Vehicle.Id">
                    @await Html.PartialAsync("_VehicleBrandBadge", booking.Vehicle)
                    <span class="ux-vehicle-inline-copy">
                        <strong>@booking.Vehicle.Brand @booking.Vehicle.Model</strong>
                        <small>@booking.Vehicle.PlateNumber</small>
                    </span>
                </a>
            </td>
            <td>@booking.PickupLocation.City to @booking.PlannedDropoffLocation.City</td>
            <td>@booking.Status</td>
            <td>
                <div class="d-flex gap-2 flex-wrap">
                    <a class="ux-table-action" asp-action="Details" asp-route-id="@booking.Id">View</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <a class="ux-table-action" asp-action="Edit" asp-route-id="@booking.Id" asp-fragment="booking-files">Datoteke</a>
                    }
                </div>
            </td>
        </tr>
    }
}
