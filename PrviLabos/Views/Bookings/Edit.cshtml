@model PrviLabos.Models.BookingEditModel
@using PrviLabos.Models

@{
    ViewData["Title"] = "Edit Booking";
}

<div class="ux-surface-card">
    <div class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Edit Booking</h2>
            <p class="ux-muted">Update booking details and route.</p>
        </div>
        <a class="ux-text-link" asp-action="Details" asp-route-id="@Model.Id">Natrag na detalje</a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="row g-3 align-items-start">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="ReservationCode" class="form-label"></label>
                <span asp-validation-for="ReservationCode" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="ReservationCode" class="form-control" />
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_AutocompleteControl", new AutocompleteControlViewModel
            {
                Name = nameof(Model.CustomerId),
                Id = "booking-customer-id",
                Label = "Customer",
                Placeholder = "Search customer...",
                SearchUrl = Url.Action("AutocompleteCustomers", "Bookings") ?? "/bookings/autocomplete/customers",
                SelectedValue = Model.CustomerId > 0 ? Model.CustomerId : null,
                SelectedText = ViewBag.CustomerDisplay as string,
                IsRequired = true
            })
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_AutocompleteControl", new AutocompleteControlViewModel
            {
                Name = nameof(Model.VehicleId),
                Id = "booking-vehicle-id",
                Label = "Vehicle",
                Placeholder = "Search vehicle...",
                SearchUrl = Url.Action("AutocompleteVehicles", "Bookings") ?? "/bookings/autocomplete/vehicles",
                SelectedValue = Model.VehicleId > 0 ? Model.VehicleId : null,
                SelectedText = ViewBag.VehicleDisplay as string,
                IsRequired = true
            })
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_AutocompleteControl", new AutocompleteControlViewModel
            {
                Name = nameof(Model.PickupLocationId),
                Id = "booking-pickup-location-id",
                Label = "Pickup Location",
                Placeholder = "Search location...",
                SearchUrl = Url.Action("AutocompleteLocations", "Bookings") ?? "/bookings/autocomplete/locations",
                SelectedValue = Model.PickupLocationId > 0 ? Model.PickupLocationId : null,
                SelectedText = ViewBag.PickupLocationDisplay as string,
                IsRequired = true
            })
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_AutocompleteControl", new AutocompleteControlViewModel
            {
                Name = nameof(Model.PlannedDropoffLocationId),
                Id = "booking-dropoff-location-id",
                Label = "Dropoff Location",
                Placeholder = "Search location...",
                SearchUrl = Url.Action("AutocompleteLocations", "Bookings") ?? "/bookings/autocomplete/locations",
                SelectedValue = Model.PlannedDropoffLocationId > 0 ? Model.PlannedDropoffLocationId : null,
                SelectedText = ViewBag.DropoffLocationDisplay as string,
                IsRequired = true
            })
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_DateTimeControl", new DateTimeControlViewModel
            {
                Name = nameof(Model.PickupAt),
                Id = "booking-pickup-at",
                Label = "Pickup Time",
                DateTimeValue = Model.PickupAt,
                IsRequired = true,
                ShowTime = true
            })
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_DateTimeControl", new DateTimeControlViewModel
            {
                Name = nameof(Model.PlannedDropoffAt),
                Id = "booking-planned-dropoff-at",
                Label = "Planned Dropoff",
                DateTimeValue = Model.PlannedDropoffAt,
                IsRequired = true,
                ShowTime = true
            })
        </div>

        <div class="col-md-6 col-xl-4">
            @await Html.PartialAsync("_DateTimeControl", new DateTimeControlViewModel
            {
                Name = nameof(Model.ActualDropoffAt),
                Id = "booking-actual-dropoff-at",
                Label = "Actual Dropoff",
                DateTimeValue = Model.ActualDropoffAt,
                IsRequired = false,
                ShowTime = true
            })
        </div>

        <div class="col-md-4 col-xl-3">
            <div class="ux-field-label-row">
                <label asp-for="TotalPrice" class="form-label"></label>
                <span asp-validation-for="TotalPrice" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="TotalPrice" class="form-control" type="number" min="0" step="0.01" />
        </div>

        <div class="col-md-4 col-xl-3">
            <div class="ux-field-label-row">
                <label asp-for="Status" class="form-label"></label>
                <span asp-validation-for="Status" class="ux-field-validation text-danger"></span>
            </div>
            <select asp-for="Status" asp-items="ViewBag.BookingStatuses" class="form-select"></select>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="ux-button-primary">Spremi</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="ux-button-secondary">Odustani</a>
        </div>
    </form>
</div>

<div class="ux-surface-card mt-4">
    <div class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Booking files</h2>
            <p class="ux-muted">Upload contracts, invoices or handover documents for this reservation.</p>
        </div>
    </div>

    <form id="bookingAttachmentDropzone"
          asp-action="UploadAttachment"
          asp-route-bookingId="@Model.Id"
          method="post"
          enctype="multipart/form-data"
          class="ux-upload-zone">
        @Html.AntiForgeryToken()
        <input id="bookingAttachmentInput" name="file" type="file" class="visually-hidden" />
        <button type="button" id="bookingAttachmentBrowse" class="ux-button-secondary">Odaberi datoteku</button>
        <span class="ux-muted">or drop a file here</span>
    </form>

    <div id="bookingAttachmentList" class="mt-3"></div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const dropzone = document.getElementById("bookingAttachmentDropzone");
            const input = document.getElementById("bookingAttachmentInput");
            const browse = document.getElementById("bookingAttachmentBrowse");
            const list = document.getElementById("bookingAttachmentList");
            const token = dropzone.querySelector("input[name='__RequestVerificationToken']").value;
            const uploadUrl = dropzone.action;
            const listUrl = "@Url.Action("GetAttachments", "Bookings", new { bookingId = Model.Id })";
            const deleteUrlTemplate = "@Url.Action("DeleteAttachment", "Bookings", new { bookingId = Model.Id, attachmentId = "__ID__" })";

            async function loadAttachments() {
                const response = await fetch(listUrl, { headers: { "X-Requested-With": "XMLHttpRequest" } });
                list.innerHTML = await response.text();
            }

            async function uploadFile(file) {
                const formData = new FormData();
                formData.append("file", file);
                formData.append("__RequestVerificationToken", token);

                const response = await fetch(uploadUrl, {
                    method: "POST",
                    body: formData,
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                if (!response.ok) {
                    alert("Upload failed.");
                    return;
                }

                input.value = "";
                await loadAttachments();
            }

            browse.addEventListener("click", () => input.click());
            input.addEventListener("change", () => {
                if (input.files.length > 0) {
                    uploadFile(input.files[0]);
                }
            });

            dropzone.addEventListener("dragover", event => {
                event.preventDefault();
                dropzone.classList.add("ux-upload-zone-active");
            });

            dropzone.addEventListener("dragleave", () => {
                dropzone.classList.remove("ux-upload-zone-active");
            });

            dropzone.addEventListener("drop", event => {
                event.preventDefault();
                dropzone.classList.remove("ux-upload-zone-active");
                if (event.dataTransfer.files.length > 0) {
                    uploadFile(event.dataTransfer.files[0]);
                }
            });

            list.addEventListener("click", async event => {
                const button = event.target.closest(".js-delete-attachment");
                if (!button) {
                    return;
                }

                const response = await fetch(deleteUrlTemplate.replace("__ID__", button.dataset.attachmentId), {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken": token,
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (!response.ok) {
                    alert("Delete failed.");
                    return;
                }

                await loadAttachments();
            });

            loadAttachments();
        })();
    </script>
}
