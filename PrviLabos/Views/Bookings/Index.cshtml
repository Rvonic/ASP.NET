@model IEnumerable<PrviLabos.Domain.Booking>
@{
    ViewData["Title"] = "Bookings";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">Bookings</span>
    </nav>
}

<section class="ux-surface-card">
    <header class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Reservation Queue</h2>
            <p class="ux-muted">Track pickup and dropoff flows across locations.</p>
        </div>
    </header>
    <div class="ux-table-wrap">
        <table class="ux-table">
            <thead>
                <tr>
                    <th>Reservation</th>
                    <th>Customer</th>
                    <th>Vehicle</th>
                    <th>Route</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td><a class="ux-text-link" asp-action="Details" asp-route-id="@booking.Id">@booking.ReservationCode</a></td>
                    <td><a class="ux-text-link" asp-controller="Customers" asp-action="Details" asp-route-id="@booking.Customer.Id">@booking.Customer.FirstName @booking.Customer.LastName</a></td>
                    <td><a class="ux-ticket-customer-link" asp-controller="Vehicles" asp-action="Details" asp-route-id="@booking.Vehicle.Id">@booking.Vehicle.Brand @booking.Vehicle.Model (@booking.Vehicle.PlateNumber)</a></td>
                    <td>@booking.PickupLocation.City to @booking.PlannedDropoffLocation.City</td>
                    <td>@booking.Status</td>
                    <td><a class="ux-table-action" asp-action="Details" asp-route-id="@booking.Id">View</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>