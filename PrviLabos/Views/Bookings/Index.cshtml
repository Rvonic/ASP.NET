@model IEnumerable<PrviLabos.Model.Booking>
@{
    ViewData["Title"] = "Bookings";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">Bookings</span>
    </nav>
}

<section class="ux-surface-card">
    <header class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Reservation Queue</h2>
            <p class="ux-muted">Track pickup and dropoff flows across locations.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <label class="visually-hidden" for="booking-search">Search bookings</label>
            <input id="booking-search"
                   class="form-control ux-booking-search"
                   type="search"
                   placeholder="Search reservation, customer, vehicle or city"
                   autocomplete="off"
                   data-ux-booking-search />
            <a class="ux-button-primary" asp-action="Create">New Booking</a>
        </div>
    </header>
    <div class="ux-table-wrap">
        <table class="ux-table" data-ux-booking-table>
            <thead>
                <tr>
                    <th>Reservation</th>
                    <th>Customer</th>
                    <th>Vehicle</th>
                    <th>Route</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody data-ux-booking-table-body>
                @await Html.PartialAsync("_BookingRows", Model)
            </tbody>
        </table>
    </div>
</section>