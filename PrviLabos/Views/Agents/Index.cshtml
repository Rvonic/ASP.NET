@model IEnumerable<PrviLabos.Model.SupportAgent>
@{
    ViewData["Title"] = "Agents";
}

@section Breadcrumbs {
    <nav class="ux-breadcrumb" aria-label="Breadcrumb">
        <a asp-controller="Home" asp-action="Index">Dashboard</a>
        <span>/</span>
        <span class="ux-breadcrumb-current" aria-current="page">Agents</span>
    </nav>
}

<section class="ux-surface-card">
    <header class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">Support Agents</h2>
            <p class="ux-muted">Team shifts, duty status, and ticket workload.</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <label class="visually-hidden" for="agent-search">Search agents</label>
            <input id="agent-search"
                   class="form-control ux-agent-search"
                   type="search"
                   placeholder="Search name, email or team"
                   autocomplete="off"
                   data-ux-agent-search />
            <a class="ux-button-primary" asp-action="Create">Novi agent</a>
        </div>
    </header>
    <div class="ux-table-wrap">
        <table class="ux-table" data-ux-agent-table>
            <thead>
                <tr>
                    <th>Agent</th>
                    <th>Team</th>
                    <th>Status</th>
                    <th>Assigned tickets</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody data-ux-agent-table-body>
                @await Html.PartialAsync("_AgentRows", Model)
            </tbody>
        </table>
    </div>
</section>
