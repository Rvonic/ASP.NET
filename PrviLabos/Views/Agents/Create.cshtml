@model PrviLabos.Models.AgentCreateModel
@using PrviLabos.Models

@{
    ViewData["Title"] = "New Agent";
}

<div class="ux-surface-card">
    <div class="ux-panel-header">
        <div>
            <h2 class="ux-section-title">New Agent</h2>
            <p class="ux-muted">Enter data for the new support team member.</p>
        </div>
        <a class="ux-text-link" asp-action="Index">Back to list</a>
    </div>

    <form asp-action="Create" method="post" class="row g-3 align-items-start">
        @Html.AntiForgeryToken()

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="FullName" class="form-label"></label>
                <span asp-validation-for="FullName" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="FullName" class="form-control" />
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="Email" class="form-label"></label>
                <span asp-validation-for="Email" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="Email" class="form-control" type="email" />
        </div>

        <div class="col-md-6 col-xl-4">
            <div class="ux-field-label-row">
                <label asp-for="TeamName" class="form-label"></label>
                <span asp-validation-for="TeamName" class="ux-field-validation text-danger"></span>
            </div>
            <input asp-for="TeamName" class="form-control" />
        </div>

        <div class="col-md-4 col-xl-3">
            @await Html.PartialAsync("_DateTimeControl", new DateTimeControlViewModel
            {
                Name = nameof(Model.ShiftStart),
                Id = "agent-shift-start",
                Label = "Shift Start",
                DateTimeValue = Model.ShiftStart,
                IsRequired = true,
                ShowTime = true
            })
        </div>

        <div class="col-md-4 col-xl-3">
            @await Html.PartialAsync("_DateTimeControl", new DateTimeControlViewModel
            {
                Name = nameof(Model.ShiftEnd),
                Id = "agent-shift-end",
                Label = "Shift End",
                DateTimeValue = Model.ShiftEnd,
                IsRequired = true,
                ShowTime = true
            })
        </div>

        <div class="col-md-4 col-xl-3 d-flex align-items-end">
            <div class="form-check">
                <input asp-for="IsOnDuty" class="form-check-input" />
                <label asp-for="IsOnDuty" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="ux-button-primary">Save</button>
            <a asp-action="Index" class="ux-button-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
